{
  "python.defaultInterpreterPath": "python3",
  "python.interpreterPath": "python3",
  "python.analysis.venvPath": "${workspaceFolder}/engine",
  "python.analysis.venv": "venv",
  "python.languageServer": "Jedi",
  "python.analysis.extraPaths": [
    "${workspaceFolder}/engine/venv/lib/python3.13/site-packages",
    "${workspaceFolder}/engine"
  ],
  "python.autoComplete.extraPaths": [
    "${workspaceFolder}/engine/venv/lib/python3.13/site-packages",
    "${workspaceFolder}/engine"
  ],
  "python.pyrefly.disableTypeErrors": true,
  "python.pyrefly.disableLanguageServices": true,
  "python.pyrefly.typeCheckingMode": "off",
  "css.lint.unknownAtRules": "ignore",
  "scss.lint.unknownAtRules": "ignore"
}
